<!DOCTYPE html>
<html lang="bn">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

{# ── category may be an object (category pages) or a string (post pages) ── #}
{% if category.title %}
  {% set catName = category.title %}
  {% set catDesc = category.description %}
  {% set isCategoryPage = true %}
{% else %}
  {% set catName = category %}
  {% set catDesc = "" %}
  {% set isCategoryPage = false %}
{% endif %}

{# ── PAGE TITLE ── #}
{% if isCategoryPage %}
  <title>{{ catName }} — লেখিকা {{ site.author.name }}-এর বাংলা লেখা | {{ site.name }}</title>
{% elif catName and author %}
  <title>{{ title }} — বাংলা {{ catName }} — লেখিকা {{ author }} | {{ site.name }}</title>
{% elif catName %}
  <title>{{ title }} — বাংলা {{ catName }} | {{ site.name }}</title>
{% elif title and title != site.tagline %}
  <title>{{ site.name }} — {{ title }}</title>
{% else %}
  <title>{{ site.name }} — {{ site.tagline }} — {{ site.author.name }}</title>
{% endif %}

{# ── META DESCRIPTION ── #}
{% if excerpt %}
  <meta name="description" content="{{ excerpt }}">
{% elif catDesc %}
  <meta name="description" content="{{ catDesc }} — লেখিকা {{ site.author.name }}-এর সংগ্রহ।">
{% elif subtitle %}
  <meta name="description" content="{{ subtitle }}">
{% else %}
  <meta name="description" content="{{ site.tagline }} — {{ site.author.name }}">
{% endif %}

{# ── CANONICAL ── #}
<link rel="canonical" href="https://kalamkatha-website.pages.dev{{ page.url }}">

{# ── OPEN GRAPH ── #}
<meta property="og:type" content="{% if isCategoryPage %}website{% elif catName %}article{% else %}website{% endif %}">
<meta property="og:site_name" content="{{ site.name }}">
{% if isCategoryPage %}
  <meta property="og:title" content="{{ catName }} — লেখিকা {{ site.author.name }}-এর বাংলা লেখা | {{ site.name }}">
{% elif catName and author %}
  <meta property="og:title" content="{{ title }} — {{ catName }} — লেখিকা {{ author }}">
{% elif catName %}
  <meta property="og:title" content="{{ title }} — {{ catName }} | {{ site.name }}">
{% else %}
  <meta property="og:title" content="{{ site.name }} — {{ site.tagline }}">
{% endif %}
{% if excerpt %}
  <meta property="og:description" content="{{ excerpt }}">
{% elif catDesc %}
  <meta property="og:description" content="{{ catDesc }} — লেখিকা {{ site.author.name }}-এর সংগ্রহ।">
{% elif subtitle %}
  <meta property="og:description" content="{{ subtitle }}">
{% else %}
  <meta property="og:description" content="{{ site.tagline }} — {{ site.author.name }}">
{% endif %}
{% if feature %}
  <meta property="og:image" content="https://kalamkatha-website.pages.dev{{ feature }}">
{% elif cover %}
  <meta property="og:image" content="https://kalamkatha-website.pages.dev{{ cover }}">
{% elif site.author.portraitImage %}
  <meta property="og:image" content="https://kalamkatha-website.pages.dev{{ site.author.portraitImage }}">
{% endif %}

{# ── ARTICLE META (posts only) ── #}
{% if category %}
  {% if date %}<meta property="article:published_time" content="{{ date | iso }}">{% endif %}
  {% if author %}<meta property="article:author" content="{{ author }}">{% endif %}
  <meta property="article:section" content="{{ category }}">
{% endif %}

{# ── TWITTER CARD ── #}
<meta name="twitter:card" content="summary_large_image">
{% if feature or cover %}
  <meta name="twitter:image" content="https://kalamkatha-website.pages.dev{{ feature or cover }}">
{% endif %}

{# ── AUTHOR ── #}
<meta name="author" content="{{ author or site.author.name }}">

<link rel="icon" href="/favicon.ico" sizes="any">
<link rel="icon" href="/favicon.svg" type="image/svg+xml">
<link rel="apple-touch-icon" href="/favicon.svg">
<link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@300;400;500;600&family=Noto+Serif+Bengali:wght@300;400;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/main.css">
<link rel="stylesheet" href="/css/post.css">
</head>
<body class="site-body">
<nav>
  <a href="/" class="nav-logo">
    কলম<span>কথা</span>
  </a>
  <button class="nav-toggle" onclick="toggleMenu()">☰</button>
  <ul class="nav-links" id="navMenu">
    <li><a href="/archive/">লেখালেখি</a></li>
    <li><a href="/books/">বই</a></li>
    <li><a href="/screenplays/">চলচ্চিত্র</a></li>
    <li><a href="/#about">পরিচয়</a></li>
    <li><a href="/#contact">যোগাযোগ</a></li>
  </ul>
</nav>

<main>
{{ content | safe }}
</main>

<footer>
  <div class="footer-logo">
    <a href="/">কলম<span>কথা</span></a>
  </div>
  <div class="footer-links">
    <a href="/archive/">লেখালেখি</a>
    <a href="/books/">বই</a>
    <a href="/screenplays/">চলচ্চিত্র</a>
    <a href="/#about">পরিচয়</a>
  </div>
  <div class="footer-copy">
    © ২০২৬ কলমকথা। সর্বস্বত্ব সংরক্ষিত।
  </div>
</footer>

<script>
function toggleMenu() {
  document.getElementById("navMenu").classList.toggle("show");
}
function scrollToTop() {
  window.scrollTo({ top: 0, behavior: "smooth" });
}
function scrollToSection(id) {
  const el = document.getElementById(id);
  if (el) el.scrollIntoView({ behavior: "smooth" });
}
</script>
</body>
</html>
