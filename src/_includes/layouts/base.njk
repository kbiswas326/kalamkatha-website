<!DOCTYPE html>
<html lang="bn">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title | default(site.name) }}</title>
<link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@300;400;500;600&family=Noto+Serif+Bengali:wght@300;400;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/main.css">
<link rel="stylesheet" href="/css/post.css">
</head>
<body>
<h1 style="background:red;color:white;padding:20px;">
THIS IS BASE.NJK
</h1>
<nav>
  <div class="nav-logo" onclick="scrollToTop()">কলম<span>কথা</span></div>
  <ul class="nav-links">
    <li><a onclick="scrollToSection('writings')">লেখালেখি</a></li>
    <li><a onclick="scrollToSection('books')">বই</a></li>
    <li><a onclick="scrollToSection('films')">চলচ্চিত্র</a></li>
    <li><a onclick="scrollToSection('about')">পরিচয়</a></li>
    <li><a onclick="scrollToSection('contact')">যোগাযোগ</a></li>
  </ul>
</nav>

{{ content | safe }}

<footer>
  <div class="footer-logo">কলম<span>কথা</span></div>
  <div class="footer-links">
    <a onclick="scrollToSection('writings')">লেখালেখি</a>
    <a onclick="scrollToSection('books')">বই</a>
    <a onclick="scrollToSection('films')">চলচ্চিত্র</a>
    <a onclick="scrollToSection('about')">পরিচয়</a>
  </div>
  <div class="footer-copy">© ২০২৬ কলমকথা। সর্বস্বত্ব সংরক্ষিত।</div>
</footer>

<script>
  function scrollToSection(id) {
    const el = document.getElementById(id);
    if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
  function scrollToTop() {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
</script>
</body>
</html>