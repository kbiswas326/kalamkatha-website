---
layout: base.njk
---

{% set categoryLinks = {
  "ছোটগল্প": "/stories/",
  "কবিতা": "/poems/",
  "উপন্যাস": "/novels/",
  "প্রবন্ধ": "/essays/",
  "চিত্রনাট্য": "/screenplays/",
  "অনুবাদ": "/translations/",
  "বই": "/books/"
} %}

<section class="post-hero">

    {% if category %}
    <div class="post-category">
        <a href="{{ categoryLinks[category] or '/archive/' }}">
            {{ category }}
        </a>
    </div>
    {% endif %}

    <h1 class="post-title">
        {{ title }}
    </h1>

    {% if subtitle %}
    <p class="post-subtitle">
        {{ subtitle }}
    </p>
    {% endif %}

    <div class="post-meta">

        <span>{{ date | bnDate }}</span>

        {% if readingTime %}
        <span>•</span>
        <span>{{ readingTime }} মিনিট পড়তে</span>
        {% endif %}

        {% if author %}
        <span>•</span>
        <span>{{ author }}</span>
        {% endif %}

    </div>

</section>

<div class="post-divider">
    <span>❦</span>
</div>

{% if feature %}
<figure class="post-feature">
    <div class="post-feature-image">
        <img src="{{ feature }}" alt="{{ title }}">
    </div>
</figure>

<div class="post-divider">
    <span>❧</span>
</div>
{% endif %}

{% if cover %}
<figure class="post-feature">
    <div class="post-feature-image">
        <img src="{{ cover }}" alt="{{ title }}">
    </div>
</figure>

<div class="post-divider">
    <span>❧</span>
</div>
{% endif %}

{% if tags %}
<div class="post-tags">
    {% for tag in tags %}
        <span class="tag">{{ tag }}</span>
    {% endfor %}
</div>
{% endif %}

<article class="post-content">
    {{ content | safe }}
</article>

<div class="post-divider">
    <span>❦</span>
</div>

<section class="related-posts">
  <div class="related-header">
    <div>
      <div class="related-label">আরও লেখা</div>
      <h2 class="related-title">আরও পড়ুন</h2>
    </div>
    <a class="related-see-all" href="/archive/">সব লেখা →</a>
  </div>

  <div class="related-grid">
    {% set ns = namespace(count=0) %}
    {% for post in collections.latest | reverse %}
      {% if post.url != page.url and ns.count < 3 %}
        <article class="related-card {% if ns.count == 0 %}related-card--featured{% else %}related-card--small{% endif %}">
          <a href="{{ post.url }}">
            {% if post.data.feature %}
              <img class="related-card-img" src="{{ post.data.feature }}" alt="{{ post.data.title }}">
            {% else %}
              <div class="related-card-img-placeholder">{{ post.data.category | first if post.data.category }}</div>
            {% endif %}
            <div class="related-card-type">{{ post.data.category }}</div>
            <h3 class="related-card-title">{{ post.data.title }}</h3>
            {% if ns.count == 0 and post.data.excerpt %}
              <p class="related-card-excerpt">{{ post.data.excerpt }}</p>
            {% endif %}
            <div class="related-card-meta">
              {{ post.date | bnDate }}
              {% if post.data.readingTime %}&nbsp;·&nbsp; {{ post.data.readingTime }} মিনিট{% endif %}
            </div>
            <span class="related-card-arrow">→</span>
          </a>
        </article>
        {% set ns.count = ns.count + 1 %}
      {% endif %}
    {% endfor %}
  </div>
</section>