---
layout: base.njk
---

{% set categoryLinks = {
  "ছোটগল্প": "/stories/",
  "কবিতা": "/poems/",
  "উপন্যাস": "/novels/",
  "প্রবন্ধ": "/essays/",
  "চিত্রনাট্য": "/screenplays/",
  "অনুবাদ": "/translations/",
  "বই": "/books/"
} %}

<nav class="post-back">
    <a href="/archive/">← সমস্ত লেখা</a>
</nav>

<section class="post-hero">

    {% if category %}
    <div class="post-category">
        <a href="{{ categoryLinks[category] or '/archive/' }}">
            {{ category }}
        </a>
    </div>
    {% endif %}

    <h1 class="post-title">
        {{ title }}
    </h1>

    {% if subtitle %}
    <p class="post-subtitle">
        {{ subtitle }}
    </p>
    {% endif %}

    <div class="post-meta">

        <span>{{ date | bnDate }}</span>

        {% if readingTime %}
        <span>•</span>
        <span>{{ readingTime }} মিনিট পড়তে</span>
        {% endif %}

        {% if author %}
        <span>•</span>
        <span>{{ author }}</span>
        {% endif %}

    </div>

</section>

<div class="post-divider">
    <span>❦</span>
</div>

{% if feature %}
<figure class="post-feature">
    <div class="post-feature-image">
        <img src="{{ feature }}" alt="{{ title }}">
    </div>
</figure>

<div class="post-divider">
    <span>❧</span>
</div>
{% endif %}

{% if cover %}
<figure class="post-feature">
    <div class="post-feature-image">
        <img src="{{ cover }}" alt="{{ title }}">
    </div>
</figure>

<div class="post-divider">
    <span>❧</span>
</div>
{% endif %}

{% if tags %}
<div class="post-tags">
    {% for tag in tags %}
        <span class="tag">{{ tag }}</span>
    {% endfor %}
</div>
{% endif %}

<article class="post-content">
    {{ content | safe }}
</article>

<div class="post-divider">
    <span>❦</span>
</div>