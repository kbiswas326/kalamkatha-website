---
layout: base.njk
---

{% set categoryLinks = {
  "ছোটগল্প": "/stories/",
  "কবিতা": "/poems/",
  "উপন্যাস": "/novels/",
  "প্রবন্ধ": "/essays/",
  "চিত্রনাট্য": "/screenplays/",
  "অনুবাদ": "/translations/",
  "বই": "/books/"
} %}

<section class="post-hero">

    {% if category %}
    <div class="post-category">
        <a href="{{ categoryLinks[category] or '/archive/' }}">
            {{ category }}
        </a>
    </div>
    {% endif %}

    <h1 class="post-title">{{ title }}</h1>

    {% if subtitle %}
    <p class="post-subtitle">{{ subtitle }}</p>
    {% endif %}

    {% if excerpt %}
    <p class="post-excerpt">{{ excerpt }}</p>
    {% endif %}

    <div class="post-meta">
        {% if date %}<span>{{ date | bnDate }}</span>{% endif %}
        {% if author %}
        <span>•</span>
        <span class="post-meta-author">
            {% if site.author.portraitImage %}
            <img class="post-meta-avatar" src="{{ site.author.portraitImage }}" alt="{{ author }}">
            {% endif %}
            {{ author }}
        </span>
        {% endif %}
    </div>

</section>

<div class="post-divider"><span>❦</span></div>

{% if feature %}
<figure class="post-feature">
    <div class="post-feature-image">
        <img src="{{ feature }}" alt="{{ title }}">
    </div>
</figure>
<div class="post-divider"><span>❧</span></div>
{% endif %}

{% if cover %}
<figure class="post-feature">
    <div class="post-feature-image">
        <img src="{{ cover }}" alt="{{ title }}">
    </div>
</figure>
<div class="post-divider"><span>❧</span></div>
{% endif %}

{% if tags %}
<div class="post-tags">
    {% for tag in tags %}
        <span class="tag">{{ tag }}</span>
    {% endfor %}
</div>
{% endif %}

<article class="post-content">
    {{ content | safe }}
</article>

<div class="post-divider"><span>❦</span></div>

<section class="related-posts">
  <div class="related-header">
    <div>
      <div class="related-label">আরও লেখা</div>
      <h2 class="related-title">আরও পড়ুন</h2>
    </div>
    <a class="related-see-all" href="/archive/">সব লেখা →</a>
  </div>

  <div class="related-grid">
    {% set relatedCount = 0 %}
    {% for post in collections.latest %}
      {% if post.url != page.url and relatedCount < 3 %}
        {% set relatedCount = relatedCount + 1 %}
        <article class="related-card {% if relatedCount == 1 %}related-card--featured{% else %}related-card--small{% endif %}">
          <a href="{{ post.url }}">
            {% if post.data.feature %}
              <img class="related-card-img" src="{{ post.data.feature }}" alt="{{ post.data.title }}">
            {% elif post.data.cover %}
              <img class="related-card-img" src="{{ post.data.cover }}" alt="{{ post.data.title }}">
            {% else %}
              <div class="related-card-img-placeholder">
                {% if post.data.category %}{{ post.data.category | truncate(2, true, '') }}{% endif %}
              </div>
            {% endif %}
            <div class="related-card-type">{{ post.data.category }}</div>
            <h3 class="related-card-title">{{ post.data.title }}</h3>
            {% if relatedCount == 1 and post.data.excerpt %}
              <p class="related-card-excerpt">{{ post.data.excerpt }}</p>
            {% endif %}
            <div class="related-card-meta">
              {% if post.date %}{{ post.date | bnDate }}{% endif %}
              {% if post.data.readingTime %}&nbsp;·&nbsp; {{ post.data.readingTime }} মিনিট{% endif %}
            </div>
            <span class="related-card-arrow">→</span>
          </a>
        </article>
      {% endif %}
    {% endfor %}
  </div>
</section>
