---
layout: base.njk
pagination:
  data: categories
  size: 1
  alias: category
permalink: "/{{ category.id }}/index.html"
---

<section class="archive-header">

    <div class="section-label">
        {{ category.title }}
    </div>

    <h1 class="section-title">
        {{ category.title }}
    </h1>

    <p class="archive-desc">
        {{ category.description }}
    </p>

</section>

<section class="archive-list">

{% for post in collections[category.id] | reverse %}

<a href="{{ post.url }}" class="featured-item">

    <span class="fi-num">

        {{ loop.index }}

    </span>

    <div class="fi-body">

        <div class="fi-type">

            {{ post.data.category }}

        </div>

        <div class="fi-title">

            {{ post.data.title }}

        </div>

        <div class="fi-excerpt">

            {{ post.data.excerpt }}

        </div>

    </div>

    <div class="fi-meta">

        {{ post.data.author }}

    </div>

</a>

{% endfor %}

</section>